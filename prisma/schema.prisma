generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id        String    @id @default(cuid())
  accountNumber  String   @unique
  firstName      String
  lastName      String
  middleName      String
  userName      String    @unique
  email     String    @unique
  phoneNumber String    @unique
  country String
  accountType String
  currency String
  pin String
  password  String

  contacts  Contact[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("users")
}

model Contact {
  id        String   @id @default(cuid())
  firstName      String
  lastName      String
  email     String
  subject   String
  message   String

  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@map("contacts")
}